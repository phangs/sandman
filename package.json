{
  "name": "sandman-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Autonomous AI Software Factory",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "dev:runner": "npm run dev -w packages/runner",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\" \"npm run dev:runner\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.0.0"
  }
}